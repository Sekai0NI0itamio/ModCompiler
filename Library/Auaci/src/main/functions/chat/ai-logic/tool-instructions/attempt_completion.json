{
  "type": "function",
  "function": {
    "name": "attempt_completion",
    "version": "1.0.0",
    "executionMode": "required",
    "description": "Finish the task with a concise, self-contained final result. Use this to finalize when the task is complete.",
    "parameters": {
      "type": "object",
      "properties": {
        "result": {
          "type": "string",
          "description": "Final result summary"
        }
      },
      "required": ["result"]
    }
  },
  "errorHandling": {
    "retryable": false,
    "commonErrors": [
      {
        "pattern": "invalid format|missing result",
        "solution": "Result summary format is incomplete",
        "suggestedAction": "Provide summary with clear completion status and key outcomes",
        "suggestedTool": null
      },
      {
        "pattern": "task not complete|incomplete",
        "solution": "Task is not yet finished",
        "suggestedAction": "Complete remaining steps before attempting completion",
        "suggestedTool": null
      }
    ]
  }
}
