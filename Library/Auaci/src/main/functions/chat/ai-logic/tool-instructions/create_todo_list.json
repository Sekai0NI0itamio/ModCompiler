{
  "type": "function",
  "function": {
    "name": "create_todo_list",
    "version": "1.0.0",
    "executionMode": "optional",
    "description": "Initialize a new todo list with tasks.",
    "parameters": {
      "type": "object",
      "properties": {
        "todos": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": {
                "type": "string",
                "description": "Task title"
              },
              "details": {
                "type": "string",
                "description": "Task details"
              }
            },
            "required": [
              "title"
            ]
          },
          "description": "Array of todo items"
        }
      },
      "required": [
        "todos"
      ]
    }
  },
  "errorHandling": {
    "retryable": false,
    "commonErrors": [
      {
        "pattern": "invalid format|malformed",
        "solution": "Todo format does not match expected structure",
        "suggestedAction": "Ensure todos array contains objects with at least 'title' field",
        "suggestedTool": "read_todos"
      },
      {
        "pattern": "list exists|already created",
        "solution": "Todo list already exists",
        "suggestedAction": "Use add_todos to add more items or read_todos to view current list",
        "suggestedTool": "read_todos"
      }
    ]
  }
}