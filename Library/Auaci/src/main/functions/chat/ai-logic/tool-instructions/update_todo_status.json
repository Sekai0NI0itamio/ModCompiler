{
  "type": "function",
  "function": {
    "name": "update_todo_status",
    "version": "1.0.0",
    "executionMode": "optional",
    "description": "Update a todo's status.",
    "parameters": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Todo ID to update"
        },
        "status": {
          "type": "string",
          "description": "New status (e.g., 'done')"
        }
      },
      "required": [
        "id",
        "status"
      ]
    }
  },
  "errorHandling": {
    "retryable": false,
    "commonErrors": [
      {
        "pattern": "not found|invalid id",
        "solution": "Todo ID does not exist",
        "suggestedAction": "Use read_todos to view available todos and their IDs",
        "suggestedTool": "read_todos"
      },
      {
        "pattern": "invalid status|bad state",
        "solution": "Status value is not valid",
        "suggestedAction": "Use valid status values like 'in-progress', 'completed', 'not-started'",
        "suggestedTool": null
      }
    ]
  }
}