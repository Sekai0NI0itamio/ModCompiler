{
  "type": "function",
  "function": {
    "name": "remove_todos",
    "version": "1.0.0",
    "executionMode": "optional",
    "description": "Remove todos from the list.",
    "parameters": {
      "type": "object",
      "properties": {
        "todo_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Array of todo IDs to remove"
        }
      },
      "required": [
        "todo_ids"
      ]
    }
  },
  "errorHandling": {
    "retryable": false,
    "commonErrors": [
      {
        "pattern": "not found|invalid id",
        "solution": "One or more todo IDs do not exist",
        "suggestedAction": "Use read_todos to view available todos and their IDs",
        "suggestedTool": "read_todos"
      },
      {
        "pattern": "protected|cannot remove",
        "solution": "Todo cannot be removed",
        "suggestedAction": "Check if todo is locked or has dependencies",
        "suggestedTool": null
      }
    ]
  }
}