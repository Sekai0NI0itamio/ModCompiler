{
  "type": "function",
  "function": {
    "name": "context_search",
    "version": "1.0.0",
    "executionMode": "optional",
    "description": "Search one or more files or directories for regex patterns.",
    "parameters": {
      "type": "object",
      "properties": {
        "paths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Array of paths to search"
        },
        "file_paths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Alternative: array of file paths"
        },
        "path": {
          "type": "string",
          "description": "Alternative: single path to search"
        },
        "queries": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Regex patterns to search for"
        },
        "patterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Alternative: patterns to search for"
        }
      },
      "required": []
    }
  },
  "errorHandling": {
    "retryable": true,
    "maxRetries": 1,
    "retryBackoff": {
      "type": "exponential",
      "initial": 500,
      "multiplier": 2,
      "max": 5000
    },
    "commonErrors": [
      {
        "pattern": "invalid regex",
        "solution": "Regex pattern syntax error",
        "suggestedTool": null
      },
      {
        "pattern": "not found|no such",
        "solution": "Path does not exist",
        "suggestedTool": "find_files"
      }
    ]
  }
}