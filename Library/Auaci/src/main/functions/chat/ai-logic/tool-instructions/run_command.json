{
  "type": "function",
  "function": {
    "name": "run_command",
    "version": "1.0.0",
    "executionMode": "optional",
    "description": "Run a non-interactive shell command in the project directory.",
    "parameters": {
      "type": "object",
      "properties": {
        "command": {
          "type": "string",
          "description": "Shell command to execute"
        }
      },
      "required": [
        "command"
      ]
    }
  },
  "errorHandling": {
    "retryable": true,
    "maxRetries": 2,
    "retryBackoff": {
      "type": "exponential",
      "initial": 1000,
      "multiplier": 2,
      "max": 10000
    },
    "commonErrors": [
      {
        "pattern": "timeout|SIGTERM",
        "solution": "Command execution timed out",
        "suggestedTool": null
      },
      {
        "pattern": "command not found",
        "solution": "Command is not available in the shell",
        "suggestedTool": null
      }
    ]
  }
}